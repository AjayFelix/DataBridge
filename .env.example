# ── PostgreSQL (source OLTP) ──────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=your_database_name
PG_USER=your_username
PG_PASSWORD=your_password
PG_SCHEMA=public

# ── DuckDB (target OLAP) ─────────────────────────────
DUCKDB_PATH=data/DataBridge_db.duckdb

# ── Staging / Incremental ────────────────────────────
STAGING_DIR=data/staging
WATERMARK_PATH=data/watermarks.json
